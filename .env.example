# OcoaBay — environment variables (NAMES ONLY; real values live in the gitignored
# .env.local / .dev.vars locally, and in Cloudflare Pages encrypted env vars in prod).
# Never commit real values.

# --- Data layer (required) ---
DATABASE_URL=            # Neon pooled connection string

# --- Admin (required for /admin) ---
ADMIN_TOKEN=             # strong random token; gates the /admin panel

# --- Email (optional; off until set) ---
RESEND_API_KEY=          # Resend API key — enables order + reservation emails
EMAIL_FROM=              # e.g. "OcoaBay <no-reply@ocoabay.com>"

# --- Payments / Stripe (optional; off until set) ---
STRIPE_SECRET_KEY=       # sk_live_… or sk_test_…
STRIPE_PUBLISHABLE_KEY=  # pk_live_… or pk_test_…  (sent to the browser)
STRIPE_WEBHOOK_SECRET=   # whsec_… from the /api/stripe-webhook endpoint config

# --- WooCommerce catalog sync (optional; only for re-syncing products) ---
WC_KEY=                  # ck_…
WC_SECRET=               # cs_…

# --- AI customer-service agent (optional; chat works as offline fallback until set) ---
ANTHROPIC_API_KEY=       # enables the live web/WhatsApp/Instagram/email agent
AGENT_MODEL=             # optional model override (default claude-haiku-4-5-20251001)

# --- Channels: Meta (WhatsApp + Instagram) ---
META_VERIFY_TOKEN=       # any string you choose; set the same in the Meta webhook config
META_APP_SECRET=         # Meta app secret (verifies webhook signatures)
WHATSAPP_TOKEN=          # WhatsApp Cloud API token
WHATSAPP_PHONE_ID=       # WhatsApp phone number id
INSTAGRAM_TOKEN=         # IG/Page access token
IG_ACCOUNT_ID=           # IG account / page id
TRANSCRIPT_EMAIL=        # where ALL chat transcripts go (default: CS@ocoabay.com); bilingual

# --- Channels: inbound email (optional) ---
POSTMARK_INBOUND_TOKEN=  # shared secret in the inbound webhook URL (?token=)

# --- Odoo (HR attendance / payroll / invoicing) ---
ODOO_URL=                # e.g. https://yourco.odoo.com (Odoo.sh)
ODOO_DB=                 # Odoo database name
ODOO_USER=               # Odoo login (email)
ODOO_API_KEY=            # Odoo API key (Settings > Account > Security > API Keys)
ODOO_EMP_MATCH_FIELD=    # hr.employee field that holds the device user-id (default: barcode)
DEVICE_SERIALS=          # comma list of allowed biometric device serial numbers (SN)
ODOO_POST_INVOICES=     # set to 1 to auto-validate (post) Odoo invoices; blank = leave as draft

# --- FX (USD->DOP) ---
FX_SOURCE_URL=        # optional override (default open.er-api.com USD feed)
