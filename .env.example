# OcoaBay — environment variables (NAMES ONLY; real values live in the gitignored
# .env.local / .dev.vars locally, and in Cloudflare Pages encrypted env vars in prod).
# Never commit real values.

# --- Data layer (required) ---
DATABASE_URL=            # Neon pooled connection string

# --- Admin (required for /admin) ---
ADMIN_TOKEN=             # strong random token; gates the /admin panel

# --- Email (optional; off until set) ---
RESEND_API_KEY=          # Resend API key — enables order + reservation emails
EMAIL_FROM=              # e.g. "OcoaBay <no-reply@ocoabay.com>"

# --- Payments / Stripe (optional; off until set) ---
STRIPE_SECRET_KEY=       # sk_live_… or sk_test_…
STRIPE_PUBLISHABLE_KEY=  # pk_live_… or pk_test_…  (sent to the browser)
STRIPE_WEBHOOK_SECRET=   # whsec_… from the /api/stripe-webhook endpoint config

# --- WooCommerce catalog sync (optional; only for re-syncing products) ---
WC_KEY=                  # ck_…
WC_SECRET=               # cs_…
