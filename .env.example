# Copy to .env and fill in. Also set these in Cloudflare Pages → Settings → Environment variables.

# Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, never ship to the browser
SUPABASE_ANON_KEY=your-anon-key                    # safe for client-side use
