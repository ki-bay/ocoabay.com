{
  "name": "ocoabay-clone",
  "version": "0.1.0",
  "private": true,
  "description": "Pixel-perfect static clone of ocoabay.com on Cloudflare Pages + Supabase",
  "scripts": {
    "dev": "npx wrangler pages dev public --compatibility-date=2024-09-01",
    "serve": "npx serve public -l 8080",
    "deploy": "npx wrangler pages deploy public --project-name=ocoabay-clone"
  },
  "devDependencies": {
    "serve": "^14.2.3",
    "wrangler": "^3.78.0"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0"
  }
}
